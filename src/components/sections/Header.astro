---
import { Icon } from "astro-icon/components";
import ThemeToggle from "@/components/ThemeToggle.astro";
import cvData from "@/config/cv.json";
import { pages } from "@/components/terminal/commands/constants";

// Mostrar apenas 3 itens visíveis, o resto vai no dropdown
const visibleItems = pages.slice(0, 3);
const hiddenItems = pages.slice(3);
---

<header class="bg-background py-4 z-10 bg-default fixed w-full">
  <div
    class="container max-w-6xl mx-auto flex justify-between items-center px-4 md:px-8"
  >
    <!-- Logo -->
    <div class="text-2xl font-bold">
      <a
        href="/"
        class="hover:text-offset flex flex-row justify-center items-center"
      >
        <img class="w-7 h-7 flex mr-3" alt="logo" src="/favicon.png" />
        <div>
          {cvData.basic.name}
          <span class="relative inline-block ml-2">
            <span class="w-[3px] h-4 bg-primary absolute bottom-0 left-0"></span>
          </span>
        </div>
      </a>
    </div>

    <div class="flex gap-5 items-center">
      <!-- PC Menu -->
      <nav class="hidden sm:flex space-x-6 items-center">
        <a
          href="/terminal"
          target="_blank"
          class="py-1 text-primary font-semi-bold relative group"
        >
          {"</Terminal>"}
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-hover:w-full transition-all duration-300"></span>
        </a>
        {
          visibleItems.map((item) => (
            <a href={item.href} class="hover:text-offset">
              {item.name}
            </a>
          ))
        }
        {hiddenItems.length > 0 && (
          <div class="relative group">
            <button class="hover:text-offset flex items-center">
              More
              <Icon name="mdi:chevron-down" class="size-4 ml-1" />
            </button>
            <div class="absolute right-0 mt-2 w-48 bg-background border border-offset rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-20">
              {
                hiddenItems.map((item) => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 hover:bg-offset first:rounded-t-md last:rounded-b-md"
                  >
                    {item.name}
                  </a>
                ))
              }
            </div>
          </div>
        )}
      </nav>

      <!-- Mobile Menu Button -->
      <div class="sm:hidden flex">
        <button id="menu-btn" class="focus:outline-none">
          <Icon name="Menu" class="size-6" />
        </button>
      </div>

      <ThemeToggle />
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden sm:hidden">
    <a
      href="/terminal"
      target="_blank"
      class="block px-4 py-2 text-primary font-semi-bold relative group"
    >
      {"</Terminal>"}
      <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-hover:w-full transition-all duration-300"></span>
    </a>
    {
      pages.map((item) => (
        <a href={item.href} class="block px-4 py-2 hover:bg-offset">
          {item.name}
        </a>
      ))
    }
  </div>
</header>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });
</script>
