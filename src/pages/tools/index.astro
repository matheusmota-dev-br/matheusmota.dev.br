---
import Layout from "@/layouts/Layout.astro";
import Portfolio from "@/components/sections/Portfolio.astro";
import toolsData from "@/config/tools.json";

const projects = toolsData.tools.map((tool) => ({
  title: tool.title,
  description: tool.description,
  url: tool.url,
  image: {
    src: tool.image.src,
    alt: tool.image.alt,
  },
  type: tool.type,
  tags: tool.tags,
}));
---

<Layout
  title="Tools"
  description="A collection of tools that I use to make my life easier."
  image="/favicon.png"
>
  <Portfolio
    section={{
      name: "Tools",
      description: "A collection of tools that I use to make my life easier.",
    }}
    projects={projects}
  />
</Layout>
