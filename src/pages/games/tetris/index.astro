---
import Layout from "@/layouts/Layout.astro";
import TetrisGame from "@/components/games/tetris";
---

<Layout
  title="Tetris Game"
  description="Play the classic Tetris game"
  image="/favicon.png"
>
  <section class="bg-background">
    <div class="container px-6 py-8 mx-auto">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4">
        <div>
          <h1 class="text-3xl font-semibold capitalize lg:text-4xl flex items-center gap-3">
            <span>🧩</span>
            Tetris Game
          </h1>
          <p class="mt-2 text-gray-600 dark:text-gray-400 lg:text-lg">
            The famous block puzzle game
          </p>
        </div>
        <a
          href="/games"
          class="text-primary hover:text-secondary transition-colors flex items-center gap-2 self-start md:self-auto"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            />
          </svg>
          Back to games
        </a>
      </div>

      <div class="flex justify-center my-8">
        <div class="relative">
          <TetrisGame client:load />
        </div>
      </div>
    </div>
  </section>
</Layout>
