---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import Resume from "@/components/sections/Resume.astro";
import Portfolio from "@/components/sections/Portfolio.astro";
import { Contact } from "@/components/sections/Contact";
import AnimateAppear from "@/components/AnimateAppear.astro";
import cvData from "@/config/cv.json";

const projects = cvData.projects;
---

<Layout
	title={cvData.basic.name}
	description={cvData.basic.summary}
	image="/profile.jpeg"
>
	<AnimateAppear>
		<Hero />
	</AnimateAppear>
	<AnimateAppear>
		<Resume />
	</AnimateAppear>
	<AnimateAppear>
		<Portfolio
			section={{
				name: "Projects",
				description: "A selection of projects I have worked on.",
			}}
			projects={projects}
		/>
	</AnimateAppear>
	<AnimateAppear>
		<Contact client:load />
	</AnimateAppear>
</Layout>
